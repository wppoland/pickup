#. Plugin Name of the plugin
#: pickup.php
msgid "Pickup - Local Pickup Scheduling for WooCommerce"
msgstr "Pickup - Planowanie odbioru osobistego dla WooCommerce"

#. Plugin URI of the plugin
#: pickup.php
msgid "https://plogins.com/pickup/"
msgstr "https://plogins.com/pickup/"

#. Description of the plugin
#: pickup.php
msgid "Let customers choose a pickup location and time slot at checkout."
msgstr "Pozwól klientom wybrać miejsce i termin odbioru podczas finalizacji zamówienia."

#. Author of the plugin
#: pickup.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: pickup.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#: pickup.php:54
msgid "Pickup - Local Pickup Scheduling for WooCommerce requires WooCommerce to be active."
msgstr "Wtyczka Pickup - Planowanie odbioru osobistego dla WooCommerce wymaga aktywnej wtyczki WooCommerce."

#: src/Admin/Settings.php:40
msgid "Pickup Scheduling"
msgstr "Planowanie odbioru"

#: src/Admin/Settings.php:41
#: src/Service/OrderDisplay.php:81
msgid "Pickup"
msgstr "Odbiór"

#: src/Admin/Settings.php:71
#: src/Admin/Settings.php:231
msgid "Remove"
msgstr "Usuń"

#: src/Admin/Settings.php:72
msgid "Remove this item?"
msgstr "Usunąć ten element?"

#: src/Admin/Settings.php:93
msgid "Pickup settings saved."
msgstr "Ustawienia odbioru zostały zapisane."

#: src/Admin/Settings.php:98
msgid "Let customers book a pickup time"
msgstr "Pozwól klientom rezerwować termin odbioru"

#: src/Admin/Settings.php:100
msgid "When an order uses WooCommerce Local Pickup, shoppers choose a location and a time slot at checkout. Define your locations, weekly opening hours, slot length and capacity below."
msgstr "Gdy zamówienie korzysta z odbioru osobistego WooCommerce, kupujący wybierają miejsce i termin podczas finalizacji zamówienia. Poniżej zdefiniuj swoje lokalizacje, tygodniowe godziny otwarcia, długość terminów i pojemność."

#: src/Admin/Settings.php:109
msgid "General"
msgstr "Ogólne"

#: src/Admin/Settings.php:111
msgid "Slot length sets how often slots repeat (30 means 09:00, 09:30, 10:00…). Capacity is how many orders may book the same location and time before it is shown as full. Lead time is the minimum notice before the earliest bookable slot. Booking horizon is how many days ahead customers may book."
msgstr "Długość terminu określa, jak często powtarzają się terminy (30 oznacza 09:00, 09:30, 10:00…). Pojemność to liczba zamówień, które mogą zarezerwować to samo miejsce i czas, zanim termin zostanie oznaczony jako zajęty. Czas wyprzedzenia to minimalny okres przed najwcześniejszym dostępnym terminem. Horyzont rezerwacji to liczba dni do przodu, na które klienci mogą rezerwować."

#: src/Admin/Settings.php:117
msgid "Enable pickup scheduling"
msgstr "Włącz planowanie odbioru"

#: src/Admin/Settings.php:122
msgid "Show pickup fields when Local Pickup is selected."
msgstr "Pokaż pola odbioru, gdy wybrano odbiór osobisty."

#: src/Admin/Settings.php:127
msgid "Slot length (minutes)"
msgstr "Długość terminu (minuty)"

#: src/Admin/Settings.php:128
msgid "Capacity per slot"
msgstr "Pojemność na termin"

#: src/Admin/Settings.php:129
msgid "Lead time (hours)"
msgstr "Czas wyprzedzenia (godziny)"

#: src/Admin/Settings.php:130
msgid "Booking horizon (days)"
msgstr "Horyzont rezerwacji (dni)"

#: src/Admin/Settings.php:137
msgid "Weekly opening hours"
msgstr "Tygodniowe godziny otwarcia"

#: src/Admin/Settings.php:139
msgid "Set one or more time windows per day using 24-hour HH:MM. Leave a day blank to close it. Slots are generated inside these windows using the slot length above."
msgstr "Ustaw jedno lub więcej okien czasowych na dzień w formacie 24-godzinnym GG:MM. Pozostaw dzień pusty, aby go zamknąć. Terminy są generowane w obrębie tych okien zgodnie z powyższą długością terminu."

#. translators: %s: weekday name.
#: src/Admin/Settings.php:154
#, php-format
msgid "%s opening time"
msgstr "Godzina otwarcia – %s"

#. translators: %s: weekday name.
#: src/Admin/Settings.php:164
#, php-format
msgid "%s closing time"
msgstr "Godzina zamknięcia – %s"

#: src/Admin/Settings.php:177
msgid "Pickup locations"
msgstr "Miejsca odbioru"

#: src/Admin/Settings.php:179
msgid "Add the places customers can collect from. Disable a location to hide it from checkout without losing its details. At least one enabled location is needed for the checkout fields to appear."
msgstr "Dodaj miejsca, z których klienci mogą odbierać zamówienia. Wyłącz lokalizację, aby ukryć ją w finalizacji zamówienia bez utraty jej danych. Aby pola odbioru się pojawiły, potrzebna jest co najmniej jedna włączona lokalizacja."

#: src/Admin/Settings.php:191
msgid "Add location"
msgstr "Dodaj lokalizację"

#: src/Admin/Settings.php:199
msgid "Save pickup settings"
msgstr "Zapisz ustawienia odbioru"

